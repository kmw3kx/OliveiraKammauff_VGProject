con 'Your game must include the following two methods in order to use the Wii Classic Controller Pro

pub SetupController(controller)               ''Set up the I2C interface through which the Wii Classic Controller Pro and the P2 chip communicate
  if controller==0
    i2c[controller].setup(10, 11, 400, i2c.PU_1K5)  'Set up I2C driver using the clock (Pin 10) and Data (Pin 11) pins' built-in 1.5K Ohm pull-up resistors
  elseif controller==1
    i2c[controller].setup(12, 13, 400, i2c.PU_1K5)
  i2c[controller].start()                       'Initialize I2C interface
  i2c[controller].write($A4)                    'Set address to $A400F0
  i2c[controller].write($F0)
  i2c[controller].write($55)                    'Write $55 to address $A4F0, which initializes nunchuck without encryption
  i2c[controller].stop()
  i2c[controller].start()
  i2c[controller].write($A4)                    'Set address to $A4FB
  i2c[controller].write($FB)
  i2c[controller].write($00)                    'Write $00 to address $A4FB,
  i2c[controller].stop()
  waitus(150)

  i2c[controller].start()
  i2c[controller].write($A4)                    'Set address to $A4FE
  i2c[controller].write($FE)
  i2c[controller].write($03)                    'Write $55 to address $A400F0, which sets data format mode to $03
  i2c[controller].stop()
  waitus(150)

pub ReadController(controller) | i            ''Have the P2 chip get the 8 bytes of data (with the button and joystick input states) from the Wii Classic Controller Pro via the I2C interface

  i2c[controller].start()                       'Send Conversion Command (to get all sensor data read and stored into the 8-byte data registers)
  i2c[controller].write($A4)                    'Set address to $A4 (the writing address)
  i2c[controller].write($00)
  i2c[controller].stop()
  waitus(250)                       'The max speed for standard I2C protocol is 400kHz, so need to slow things down a little (may need to experiment with this depending on your controller and main loop time)

  i2c[controller].start()
  i2c[controller].write($A5)                    'Set address to $A5 (the start of where controller's input data is stored and read from)
  if controller == 0
    repeat i from 0 to 6
      data[i]:=i2c[controller].read(0)            'Read in byte, store it to data array, then send 0=ACK
    data[7]:=i2c[controller].read(1)              'Read in byte, store it to data array, then send 1=NAK (after the last byte)
  elseif controller==1
    repeat i from 0 to 6
      data[i+8]:=i2c[controller].read(0)            'Read in byte, store it to data array, then send 0=ACK
    data[7+8]:=i2c[controller].read(1)              'Read in byte, store it to data array, then send 1=NAK (after the last byte)
  i2c[controller].stop()



pub EnemyMotion()
  if BulletHealth > 16
    repeat
      repeat until BulletB[0]<=0
        BulletB[0]:=BulletB[0]-6
        waitms(175)
      BulletRot:= 0
      repeat until BulletB[0]>=800
        BulletB[0]:=BulletB[0]+6
        waitms(175)
      BulletRot:= 1

pub PikminMotion() | RPikminPosX, RPikminPosY, YPikminPosX, YPikminPosY, BPikminPosX, BPikminPosY, i
  RPikminPosX := Pikmin[0]
  RPikminPosY := Pikmin[1]
  YPikminPosX := Pikmin[4]
  YPikminPosY := Pikmin[5]

  repeat
      if PikminHealth[0] > 16
        if Pikmin[0] > 16
          repeat i from 0 to 4
            Pikmin[0]:=Pikmin[0]-16
            waitms(175)
        else
          Pikmin[0]:= 750
        RPikminPosX := Pikmin[0]
        if Pikmin[1] < 250
          repeat i from 0 to 4
            Pikmin[1]:=Pikmin[1]+16
            waitms(175)
        else
          repeat i from 0 to 4
            Pikmin[1]:=Pikmin[1]-16
            waitms(175)
        RPikminPosY := Pikmin[1]
      if PikminHealth[1] > 16
        if Pikmin[4] > 16
          repeat i from 0 to 4
            Pikmin[4]:=Pikmin[4]-32
            waitms(175)
        else
          Pikmin[4]:= 750
        YPikminPosX := Pikmin[0]
        if Pikmin[5] < 250
          repeat i from 0 to 4
            Pikmin[5]:=Pikmin[5]+32
            waitms(175)
        else
          repeat i from 0 to 4
            Pikmin[5]:=Pikmin[5]-24
            waitms(175)
        YPikminPosY := Pikmin[5]
      if PikminHealth[2] > 16
        if Pikmin[8] > 16
          repeat i from 0 to 4
            Pikmin[8]:=Pikmin[8]-16
            waitms(175)
        else
          Pikmin[8]:= 750
        BPikminPosX := Pikmin[8]
        if Pikmin[9] < 250
          repeat i from 0 to 4
            Pikmin[9]:=Pikmin[9]+16
            waitms(175)
        else
          repeat i from 0 to 4
            Pikmin[9]:=Pikmin[9]-16
            waitms(175)
        BPikminPosY := Pikmin[9]

pub EasterEgg()

repeat
  repeat until (data[6].[5]==0 and data[7].[7]==0 and data[6].[1]==0 and data[7].[2]==0) or (data[6+8].[5]==0 and data[7+8].[7]==0 and data[6+8].[1]==0 and data[7+8].[2]==0)
    waitms(FrameTime)

  {pvpState toggle}
  case pvpState
    true : pvpState:=false
    false : pvpState:=true
  repeat until data[6].[1] == 1 and data[6+8].[1] == 1
    waitms(FrameTime)
  waitms(FrameTime)
