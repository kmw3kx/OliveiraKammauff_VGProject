'This external object holds all of the data needed to define the sprites that your game uses
con _clkfreq = 300_000_000
pub null()                                                      'This is not a top level object
  debug(`term term2 pos 100 0 size 52 2 textsize 18 color red)  'If you see this message, then...
  debug(`term2 'Oops! You have accidentally compiled and run an     external object instead of your top-level game code!')

pub LoadSprites() | i    'Call methods or debug commands to load sprite data from your P2 chip into your PC's RAM when your program starts. You can define up to 256 total sprites at once (sprite numbers 0-255)
  load_Lake_sprites()

